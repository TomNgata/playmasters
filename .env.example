# Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url_here
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# Used for resolving full URL paths (e.g. email confirmations)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Required for Supabase Auth Admin operations (e.g. inviting users)
# IMPORTANT: Never prefix this with NEXT_PUBLIC_ as it should only be used server-side
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here
